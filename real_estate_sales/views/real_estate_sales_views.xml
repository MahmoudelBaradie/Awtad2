<odoo>

<record id="view_re_sale_tree" model="ir.ui.view"><field name="name">re.sale.tree</field><field name="model">real.estate.sale</field><field name="arch" type="xml"><tree><field name="name"/><field name="partner_id"/><field name="unit_id"/><field name="sale_price"/><field name="margin"/><field name="state"/></tree></field></record>
