<record id="action_re_sale" model="ir.actions.act_window"><field name="name">Unit Sales</field><field name="res_model">real.estate.sale</field><field name="view_mode">tree,form</field></record>
<menuitem id="menu_re_sale" parent="real_estate_core.menu_real_estate_root" name="Sales" action="action_re_sale"/>

