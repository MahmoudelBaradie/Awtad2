<odoo>
    <record id="seq_real_estate_land" model="ir.sequence">
        <field name="name">Land Sequence</field>
        <field name="code">real.estate.land</field>
        <field name="prefix">LAND/%(year)s/</field>
        <field name="padding">4</field>
    </record>
    <record id="seq_real_estate_project" model="ir.sequence">
        <field name="name">Project Sequence</field>
        <field name="code">real.estate.project</field>
        <field name="prefix">PROJ/%(year)s/</field>
        <field name="padding">4</field>
    </record>
    <record id="seq_real_estate_unit" model="ir.sequence">
        <field name="name">Unit Sequence</field>
        <field name="code">real.estate.unit</field>
        <field name="prefix">UNIT/%(year)s/</field>
        <field name="padding">5</field>
    </record>
</odoo>
